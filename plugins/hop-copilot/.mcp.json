{
  "mcpServers": {
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "confluence-delta-patch": {
      "command": "npx",
      "args": ["confluence-delta-patch"],
      "env": {
        "ATLASSIAN_SITE_URL": "https://endios.atlassian.net",
        "ATLASSIAN_USER_EMAIL": "${ATLASSIAN_USER_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      }
    }
  }
}
